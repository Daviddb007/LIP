# Laboratorio de Inteligencia Pública V3 — Variables de entorno
# Copiar a .env y completar los valores

# Flask
FLASK_CONFIG=production
SECRET_KEY=cambiar-esta-clave-en-produccion

# Base de datos
DATABASE_URL=postgresql://construyamos:construyamos@db:5432/construyamos_v3

# Admin
ADMIN_USER=admin
ADMIN_PASS=hash-pbkdf2-generado-con-generate_password.py

# Redis (rate limiting + cache)
RATELIMIT_STORAGE_URI=redis://redis:6379/0
CACHE_TYPE=RedisCache
CACHE_REDIS_URL=redis://redis:6379/1

# App
PORT=8000
LOG_LEVEL=info

# Plan activo (ID del plan estratégico a usar)
PLAN_ACTIVO_ID=1

# SSL
PREFERRED_URL_SCHEME=https
