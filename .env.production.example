# Production Environment Configuration
# Copy this file to .env and fill in the values

# Flask environment
FLASK_CONFIG=production

# Security - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_HEX_STRING

# Database - PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/construyamos_colombia

# Admin credentials - Generate password hash with: python generate_password.py <password>
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME_TO_HASHED_PASSWORD

# Rate limiting - Use Redis in production
RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# Caching - Use Redis in production
CACHE_TYPE=RedisCache
CACHE_REDIS_URL=redis://localhost:6379/1

# Server
PORT=8000
LOG_LEVEL=info
